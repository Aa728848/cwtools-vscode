{
	"compilerOptions": {
		"noImplicitReturns": true,
		"target": "es2020",
		"module": "commonjs",
		"moduleResolution": "node",
		"rootDir": "client",
		"outDir": "release/bin/client",
		"lib": [ "es2020", "dom" ],
		"sourceMap": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"strict": true
		// TODO: Enable noUncheckedIndexedAccess — requires fixing ~250+ array/buffer index
		// accesses across ddsDecoder, guiParser, solarSystemParser, solarSystemPanel, etc.
	},
	"include": [
		"client"
	],
	"exclude": [
		"node_modules",
		"server",
		"paket-files",
		".vscode-test"
	]
}