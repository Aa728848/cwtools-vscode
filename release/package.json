{
	"name": "eddy-stellaris-cwt",
	"displayName": "%extension.displayName%",
	"private": true,
	"description": "%extension.description%",
	"author": "Eddy",
	"license": "MIT",
	"version": "1.7.0",
	"preview": true,
	"activationEvents": [
		"onLanguage:stellaris",
		"onLanguage:hoi4",
		"onLanguage:eu4",
		"onLanguage:ck2",
		"onLanguage:imperator",
		"onLanguage:vic2",
		"onLanguage:vic3",
		"onLanguage:ck3",
		"onLanguage:eu5",
		"onLanguage:paradox",
		"onLanguage:yaml",
		"onCommand:cwtools.ai.configure"
	],
	"publisher": "Eddy",
	"icon": "docs/stellaris.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/Aa728848/cwtools-vscode"
	},
	"homepage": "https://github.com/cwtools/cwtools-vscode",
	"engines": {
		"vscode": "^1.83.0"
	},
	"categories": [
		"Programming Languages",
		"Linters"
	],
	"keywords": [
		"paradox",
		"stellaris",
		"victoria",
		"crusader kings",
		"hearts of iron"
	],
	"main": "./bin/client/extension/extension.js",
	"contributes": {
		"views": {
			"explorer": [
				{
					"id": "cwtools-files",
					"name": "%views.cwtools-files.name%"
				}
			],
			"cwtools-ai-panel": [
				{
					"type": "webview",
					"id": "cwtools.aiChat",
					"name": "AI Assistant"
				}
			]
		},
		"viewsContainers": {
			"secondarySidebar": [
				{
					"id": "cwtools-ai-panel",
					"title": "%viewsContainers.cwtools-ai-panel.title%",
					"icon": "$(sparkle)"
				}
			]
		},
		"menus": {
			"editor/title": [
				{
					"command": "cwtools.ai.openChat",
					"group": "navigation@0",
					"when": "true"
				},
				{
					"command": "cwtools.toggleInlineTextOn",
					"when": "!config.cwtools.showInlineText",
					"group": "navigation"
				},
				{
					"command": "cwtools.toggleInlineTextOff",
					"when": "config.cwtools.showInlineText",
					"group": "navigation"
				},
				{
					"command": "cwtools.previewGUI",
					"when": "resourceExtname == .gui",
					"group": "navigation"
				},
				{
					"command": "cwtools.previewSolarSystem",
					"when": "resourceExtname == .txt && resourcePath =~ /solar_system_initializers/",
					"group": "navigation"
				}
			]
		},
		"commands": [
			{
				"command": "outputerrors",
				"title": "%commands.outputerrors.title%",
				"category": "cwtools"
			},
			{
				"command": "genlocall",
				"title": "%commands.genlocall.title%",
				"category": "cwtools"
			},
			{
				"command": "reloadrulesconfig",
				"title": "%commands.reloadrulesconfig.title%",
				"category": "cwtools"
			},
			{
				"command": "cacheVanilla",
				"title": "%commands.cacheVanilla.title%",
				"category": "cwtools"
			},
			{
				"command": "listAllFiles",
				"title": "%commands.listAllFiles.title%",
				"category": "cwtools"
			},
			{
				"command": "listAllLocFiles",
				"title": "%commands.listAllLocFiles.title%",
				"category": "cwtools"
			},
			{
				"command": "debugrules",
				"title": "%commands.debugrules.title%",
				"category": "cwtools"
			},
			{
				"command": "pretriggerAllFiles",
				"title": "%commands.pretriggerAllFiles.title%",
				"category": "cwtools"
			},
			{
				"command": "startcustomgame",
				"title": "%commands.startcustomgame.title%",
				"category": "cwtools"
			},
			{
				"command": "exportTypes",
				"title": "%commands.exportTypes.title%",
				"category": "cwtools"
			},
			{
				"command": "cwtools.toggleInlineTextOn",
				"title": "%commands.cwtools.toggleInlineTextOn.title%",
				"category": "cwtools",
				"icon": "$(eye-closed)"
			},
			{
				"command": "cwtools.toggleInlineTextOff",
				"title": "%commands.cwtools.toggleInlineTextOff.title%",
				"category": "cwtools",
				"icon": "$(eye)"
			},
			{
				"command": "cwtools.previewGUI",
				"title": "%commands.cwtools.previewGUI.title%",
				"category": "cwtools",
				"icon": "$(open-preview)"
			},
			{
				"command": "cwtools.previewSolarSystem",
				"title": "%commands.cwtools.previewSolarSystem.title%",
				"category": "cwtools",
				"icon": "$(telescope)"
			},
			{
				"command": "cwtools.ai.configure",
				"title": "%commands.cwtools.ai.configure%",
				"category": "CWTools AI"
			},
			{
				"command": "cwtools.ai.openChat",
				"title": "%commands.cwtools.ai.openChat%",
				"category": "CWTools AI",
				"icon": "$(sparkle)"
			},
			{
				"command": "cwtools.ai.selectModel",
				"title": "%commands.cwtools.ai.selectModel.title%",
				"category": "CWTools AI"
			},
			{
				"command": "cwtools.ai.reviewFile",
				"title": "%commands.cwtools.ai.reviewFile.title%",
				"category": "CWTools AI",
				"icon": "$(search)"
			},
			{
				"command": "cwtools.ai.explainSelection",
				"title": "%commands.cwtools.ai.explainSelection.title%",
				"category": "CWTools AI",
				"icon": "$(lightbulb)"
			},
			{
				"command": "cwtools.ai.fixDiagnostics",
				"title": "%commands.cwtools.ai.fixDiagnostics.title%",
				"category": "CWTools AI",
				"icon": "$(wrench)"
			}
		],
		"keybindings": [
			{
				"command": "cwtools.ai.reviewFile",
				"key": "ctrl+shift+r",
				"mac": "cmd+shift+r",
				"when": "editorTextFocus"
			},
			{
				"command": "cwtools.ai.explainSelection",
				"key": "ctrl+shift+e",
				"mac": "cmd+shift+e",
				"when": "editorHasSelection"
			},
			{
				"command": "cwtools.ai.fixDiagnostics",
				"key": "ctrl+shift+f",
				"mac": "cmd+shift+f",
				"when": "editorTextFocus"
			}
		],
		"configuration": {
			"type": "object",
			"title": "%configuration.title%",
			"properties": {
				"cwtools.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "%configuration.cwtools.trace.server.description%"
				},
				"cwtools.localisation.languages": {
					"scope": "window",
					"type": "array",
					"items": {
						"type": "string",
						"enum": [
							"English",
							"French",
							"German",
							"Spanish",
							"Russian",
							"Braz_Por",
							"Polish",
							"Chinese",
							"Korean",
							"Japanese",
							"Turkish"
						]
					},
					"default": [
						"English"
					],
					"description": "%configuration.cwtools.localisation.languages.description%",
					"uniqueItems": true
				},
				"cwtools.localisation.generated_strings": {
					"scope": "window",
					"type": "string",
					"default": ":0 \"REPLACE_ME\"",
					"description": "%configuration.cwtools.localisation.generated_strings.description%"
				},
				"cwtools.errors.vanilla": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.errors.vanilla.description%"
				},
				"cwtools.errors.ignore": {
					"scope": "window",
					"type": "array",
					"description": "%configuration.cwtools.errors.ignore.description%",
					"uniqueItems": true
				},
				"cwtools.errors.ignorefiles": {
					"scope": "window",
					"type": "array",
					"description": "%configuration.cwtools.errors.ignorefiles.description%",
					"uniqueItems": true,
					"default": [
						"README.txt",
						"credits.txt",
						"credits_l_simp_chinese.txt",
						"reference.txt",
						"startup_info.txt"
					]
				},
				"cwtools.experimental": {
					"scope": "window",
					"type": "boolean",
					"default": true,
					"description": "%configuration.cwtools.experimental.description%"
				},
				"cwtools.debug_mode": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.debug_mode.description%"
				},
				"cwtools.showInlineText": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.showInlineText.description%"
				},
				"cwtools.logging.diagnostic": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.logging.diagnostic.description%"
				},
				"cwtools.rules_version": {
					"scope": "window",
					"type": "string",
					"enum": [
						"stable",
						"latest",
						"manual"
					],
					"default": "latest",
					"description": "%configuration.cwtools.rules_version.description%"
				},
				"cwtools.rules_folder": {
					"scope": "window",
					"type": "string",
					"description": "%configuration.cwtools.rules_folder.description%"
				},
				"cwtools.rulesProxy": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.rulesProxy.description%",
					"default": ""
				},
				"cwtools.ignore_patterns": {
					"scope": "window",
					"type": "array",
					"description": "%configuration.cwtools.ignore_patterns.description%",
					"uniqueItems": true,
					"default": [
						"**/99_README**.txt"
					]
				},
				"cwtools.cache.eu4": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.eu4.description%"
				},
				"cwtools.cache.hoi4": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.hoi4.description%"
				},
				"cwtools.cache.stellaris": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.stellaris.description%"
				},
				"cwtools.cache.ck2": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.ck2.description%"
				},
				"cwtools.cache.imperator": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.imperator.description%"
				},
				"cwtools.cache.vic2": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.vic2.description%"
				},
				"cwtools.cache.ck3": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.ck3.description%"
				},
				"cwtools.cache.vic3": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.vic3.description%"
				},
				"cwtools.cache.eu5": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.eu5.description%"
				},
				"cwtools.maxFileSize": {
					"scope": "resource",
					"type": "integer",
					"minimum": 1,
					"default": 2,
					"description": "%configuration.cwtools.maxFileSize.description%"
				},
				"cwtools.checkForUpdates": {
					"scope": "window",
					"type": "boolean",
					"default": true,
					"description": "%configuration.cwtools.checkForUpdates.description%"
				},
				"cwtools.ai.enabled": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.ai.enabled.description%"
				},
				"cwtools.ai.provider": {
					"scope": "window",
					"type": "string",
					"enum": [
						"openai",
						"claude",
						"deepseek",
						"minimax",
						"glm",
						"qwen",
						"ollama",
						"siliconflow",
						"openrouter",
						"github",
						"together",
						"deepinfra"
					],
					"enumDescriptions": [
						"%configuration.cwtools.ai.provider.enum.openai%",
						"%configuration.cwtools.ai.provider.enum.claude%",
						"%configuration.cwtools.ai.provider.enum.deepseek%",
						"%configuration.cwtools.ai.provider.enum.minimax%",
						"%configuration.cwtools.ai.provider.enum.glm%",
						"%configuration.cwtools.ai.provider.enum.qwen%",
						"%configuration.cwtools.ai.provider.enum.ollama%",
						"%configuration.cwtools.ai.provider.enum.siliconflow%",
						"%configuration.cwtools.ai.provider.enum.openrouter%",
						"%configuration.cwtools.ai.provider.enum.github%",
						"%configuration.cwtools.ai.provider.enum.together%",
						"%configuration.cwtools.ai.provider.enum.deepinfra%"
					],
					"default": "openai",
					"description": "%configuration.cwtools.ai.provider.description%"
				},
				"cwtools.ai.model": {
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "%configuration.cwtools.ai.model.description%"
				},
				"cwtools.ai.endpoint": {
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "%configuration.cwtools.ai.endpoint.description%"
				},
				"cwtools.ai.agentFileWriteMode": {
					"scope": "window",
					"type": "string",
					"enum": [
						"confirm",
						"auto"
					],
					"enumDescriptions": [
						"%configuration.cwtools.ai.agentFileWriteMode.enum.confirm%",
						"%configuration.cwtools.ai.agentFileWriteMode.enum.auto%"
					],
					"default": "confirm",
					"description": "%configuration.cwtools.ai.agentFileWriteMode.description%"
				},
				"cwtools.ai.forcedThinkingMode": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.ai.forcedThinkingMode.description%"
				},
				"cwtools.ai.maxRetries": {
					"scope": "window",
					"type": "integer",
					"default": 3,
					"minimum": 1,
					"maximum": 5,
					"description": "%configuration.cwtools.ai.maxRetries.description%"
				},
				"cwtools.ai.reasoningEffort": {
					"scope": "window",
					"type": "string",
					"enum": [
						"low",
						"medium",
						"high",
						"max"
					],
					"enumDescriptions": [
						"%configuration.cwtools.ai.reasoningEffort.enum.low%",
						"%configuration.cwtools.ai.reasoningEffort.enum.medium%",
						"%configuration.cwtools.ai.reasoningEffort.enum.high%",
						"%configuration.cwtools.ai.reasoningEffort.enum.max%"
					],
					"default": "high",
					"description": "%configuration.cwtools.ai.reasoningEffort.description%"
				},
				"cwtools.ai.maxContextTokens": {
					"scope": "window",
					"type": "integer",
					"default": 0,
					"minimum": 0,
					"maximum": 10000000,
					"description": "%configuration.cwtools.ai.maxContextTokens.description%"
				},
				"cwtools.ai.inlineCompletion.enabled": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.ai.inlineCompletion.enabled.description%"
				},
				"cwtools.ai.inlineCompletion.fimMode": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.ai.inlineCompletion.fimMode.description%"
				},
				"cwtools.ai.inlineCompletion.debounceMs": {
					"scope": "window",
					"type": "integer",
					"default": 500,
					"minimum": 200,
					"maximum": 5000,
					"description": "%configuration.cwtools.ai.inlineCompletion.debounceMs.description%"
				},
				"cwtools.ai.inlineCompletion.overlapStripping": {
					"scope": "window",
					"type": "boolean",
					"default": true,
					"description": "%configuration.cwtools.ai.inlineCompletion.overlapStripping.description%"
				},
				"cwtools.ai.inlineCompletion.provider": {
					"scope": "window",
					"type": "string",
					"enum": [
						"openai",
						"claude",
						"deepseek",
						"minimax",
						"glm",
						"qwen",
						"ollama",
						"siliconflow",
						"openrouter",
						"github",
						"together",
						"deepinfra"
					],
					"enumDescriptions": [
						"%configuration.cwtools.ai.provider.enum.openai%",
						"%configuration.cwtools.ai.provider.enum.claude%",
						"%configuration.cwtools.ai.provider.enum.deepseek%",
						"%configuration.cwtools.ai.provider.enum.minimax%",
						"%configuration.cwtools.ai.provider.enum.glm%",
						"%configuration.cwtools.ai.provider.enum.qwen%",
						"%configuration.cwtools.ai.provider.enum.ollama%",
						"%configuration.cwtools.ai.provider.enum.siliconflow%",
						"%configuration.cwtools.ai.provider.enum.openrouter%",
						"%configuration.cwtools.ai.provider.enum.github%",
						"%configuration.cwtools.ai.provider.enum.together%",
						"%configuration.cwtools.ai.provider.enum.deepinfra%"
					],
					"default": "",
					"description": "%configuration.cwtools.ai.inlineCompletion.provider.description%"
				},
				"cwtools.ai.inlineCompletion.model": {
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "%configuration.cwtools.ai.inlineCompletion.model.description%"
				},
				"cwtools.ai.inlineCompletion.endpoint": {
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "%configuration.cwtools.ai.inlineCompletion.endpoint.description%"
				},
				"cwtools.ai.dynamicModels": {
					"type": "object",
					"default": {},
					"description": "%configuration.cwtools.ai.dynamicModels.description%"
				},
				"cwtools.ai.dynamicModelsContext": {
					"type": "object",
					"default": {},
					"description": "%configuration.cwtools.ai.dynamicModelsContext.description%"
				}
			}
		},
		"languages": [
			{
				"id": "stellaris",
				"aliases": [
					"",
					"paradox",
					"pdxscript"
				],
				"extensions": [
					"txt",
					"gui",
					"gfx",
					"asset",
					"cwt"
				],
				"configuration": "./language-configuration.json",
				"filenamePatterns": [
					"**/stellaris*/**/*.txt",
					"**/stellaris*/**/*.gui",
					"**/stellaris*/**/*.gfx",
					"**/stellaris*/**/*.asset"
				]
			},
			{
				"id": "hoi4",
				"aliases": [
					"",
					"paradox",
					"pdxscript"
				],
				"extensions": [
					"txt",
					"gui",
					"gfx",
					"asset",
					"cwt"
				],
				"configuration": "./language-configuration.json",
				"filenamePatterns": [
					"**/hearts*of*iron*iv*/**/*.txt",
					"**/hearts*of*iron*iv*/**/*.gui",
					"**/hearts*of*iron*iv*/**/*.gfx",
					"**/hearts*of*iron*iv*/**/*.asset"
				]
			},
			{
				"id": "eu4",
				"aliases": [
					"",
					"paradox",
					"pdxscript"
				],
				"extensions": [
					"txt",
					"gui",
					"gfx",
					"asset",
					"cwt"
				],
				"configuration": "./language-configuration.json",
				"filenamePatterns": [
					"**/europa*universalis*iv/**/*.txt",
					"**/europa*universalis*iv/**/*.gui",
					"**/europa*universalis*iv/**/*.gfx",
					"**/europa*universalis*iv/**/*.asset"
				]
			},
			{
				"id": "ck2",
				"aliases": [
					"",
					"paradox",
					"pdxscript"
				],
				"extensions": [
					"txt",
					"gui",
					"gfx",
					"sfx",
					"asset",
					"cwt"
				],
				"configuration": "./language-configuration.json",
				"filenamePatterns": [
					"**/crusader*kings*ii/**/*.txt",
					"**/crusader*kings*ii/**/*.gui",
					"**/crusader*kings*ii/**/*.gfx",
					"**/crusader*kings*ii/**/*.sfx",
					"**/crusader*kings*ii/**/*.asset"
				]
			},
			{
				"id": "imperator",
