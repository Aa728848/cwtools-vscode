{
	"name": "eddy-stellaris-cwt",
	"displayName": "%extension.displayName%",
	"private": true,
	"description": "%extension.description%",
	"author": "Dayshine",
	"license": "MIT",
	"version": "1.5.0",
	"preview": true,
	"publisher": "Eddy",
	"icon": "docs/stellaris.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/Aa728848/cwtools-vscode"
	},
	"homepage": "https://github.com/cwtools/cwtools-vscode",
	"engines": {
		"vscode": "^1.83.0"
	},
	"categories": [
		"Programming Languages",
		"Linters"
	],
	"keywords": [
		"paradox",
		"stellaris",
		"victoria",
		"crusader kings",
		"hearts of iron"
	],
	"main": "./bin/client/extension/extension.js",
	"contributes": {
		"views": {
			"explorer": [
				{
					"id": "cwtools-files",
					"name": "%views.cwtools-files.name%"
				}
			],
			"cwtools-ai-panel": [
				{
					"type": "webview",
					"id": "cwtools.aiChat",
					"name": "AI Assistant"
				}
			]
		},
		"viewsContainers": {
			"secondarySidebar": [
				{
					"id": "cwtools-ai-panel",
					"title": "CWTools AI",
					"icon": "$(sparkle)"
				}
			]
		},
		"menus": {
			"editor/title": [
				{
					"command": "cwtools.ai.openChat",
					"group": "navigation@0",
					"when": "true"
				},
				{
					"command": "cwtools.toggleInlineTextOn",
					"when": "!config.cwtools.showInlineText",
					"group": "navigation"
				},
				{
					"command": "cwtools.toggleInlineTextOff",
					"when": "config.cwtools.showInlineText",
					"group": "navigation"
				},
				{
					"command": "cwtools.previewGUI",
					"when": "resourceExtname == .gui",
					"group": "navigation"
				},
				{
					"command": "cwtools.previewSolarSystem",
					"when": "resourceExtname == .txt && resourcePath =~ /solar_system_initializers/",
					"group": "navigation"
				}
			]
		},
		"commands": [
			{
				"command": "outputerrors",
				"title": "%commands.outputerrors.title%",
				"category": "cwtools"
			},
			{
				"command": "genlocall",
				"title": "%commands.genlocall.title%",
				"category": "cwtools"
			},
			{
				"command": "reloadrulesconfig",
				"title": "%commands.reloadrulesconfig.title%",
				"category": "cwtools"
			},
			{
				"command": "cacheVanilla",
				"title": "%commands.cacheVanilla.title%",
				"category": "cwtools"
			},
			{
				"command": "listAllFiles",
				"title": "%commands.listAllFiles.title%",
				"category": "cwtools"
			},
			{
				"command": "listAllLocFiles",
				"title": "%commands.listAllLocFiles.title%",
				"category": "cwtools"
			},
			{
				"command": "debugrules",
				"title": "%commands.debugrules.title%",
				"category": "cwtools"
			},
			{
				"command": "pretriggerAllFiles",
				"title": "%commands.pretriggerAllFiles.title%",
				"category": "cwtools"
			},
			{
				"command": "startcustomgame",
				"title": "%commands.startcustomgame.title%",
				"category": "cwtools"
			},
			{
				"command": "exportTypes",
				"title": "%commands.exportTypes.title%",
				"category": "cwtools"
			},
			{
				"command": "cwtools.toggleInlineTextOn",
				"title": "Enable Inline Text",
				"category": "cwtools",
				"icon": "$(eye-closed)"
			},
			{
				"command": "cwtools.toggleInlineTextOff",
				"title": "Disable Inline Text",
				"category": "cwtools",
				"icon": "$(eye)"
			},
			{
				"command": "cwtools.previewGUI",
				"title": "Preview GUI Layout",
				"category": "cwtools",
				"icon": "$(open-preview)"
			},
			{
				"command": "cwtools.previewSolarSystem",
				"title": "Preview Solar System",
				"category": "cwtools",
				"icon": "$(telescope)"
			},
			{
				"command": "cwtools.ai.configure",
				"title": "Configure AI Provider",
				"category": "CWTools AI"
			},
			{
				"command": "cwtools.ai.openChat",
				"title": "Open AI Chat",
				"category": "CWTools AI",
				"icon": "$(sparkle)"
			}
		],
		"configuration": {
			"type": "object",
			"title": "%configuration.title%",
			"properties": {
				"cwtools.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "%configuration.cwtools.trace.server.description%"
				},
				"cwtools.localisation.languages": {
					"scope": "window",
					"type": "array",
					"items": {
						"type": "string",
						"enum": [
							"English",
							"French",
							"German",
							"Spanish",
							"Russian",
							"Braz_Por",
							"Polish",
							"Chinese",
							"Korean",
							"Japanese",
							"Turkish"
						]
					},
					"default": [
						"English"
					],
					"description": "%configuration.cwtools.localisation.languages.description%",
					"uniqueItems": true
				},
				"cwtools.localisation.generated_strings": {
					"scope": "window",
					"type": "string",
					"default": ":0 \"REPLACE_ME\"",
					"description": "%configuration.cwtools.localisation.generated_strings.description%"
				},
				"cwtools.errors.vanilla": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.errors.vanilla.description%"
				},
				"cwtools.errors.ignore": {
					"scope": "window",
					"type": "array",
					"description": "%configuration.cwtools.errors.ignore.description%",
					"uniqueItems": true
				},
				"cwtools.errors.ignorefiles": {
					"scope": "window",
					"type": "array",
					"description": "%configuration.cwtools.errors.ignorefiles.description%",
					"uniqueItems": true,
					"default": [
						"README.txt",
						"credits.txt",
						"credits_l_simp_chinese.txt",
						"reference.txt",
						"startup_info.txt"
					]
				},
				"cwtools.experimental": {
					"scope": "window",
					"type": "boolean",
					"default": true,
					"description": "%configuration.cwtools.experimental.description%"
				},
				"cwtools.debug_mode": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.debug_mode.description%"
				},
				"cwtools.showInlineText": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "Show localisation and references directly above the code instead of hovering."
				},
				"cwtools.logging.diagnostic": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.cwtools.logging.diagnostic.description%"
				},
				"cwtools.rules_version": {
					"scope": "window",
					"type": "string",
					"enum": [
						"stable",
						"latest",
						"manual"
					],
					"default": "latest",
					"description": "%configuration.cwtools.rules_version.description%"
				},
				"cwtools.rules_folder": {
					"scope": "window",
					"type": "string",
					"description": "%configuration.cwtools.rules_folder.description%"
				},
				"cwtools.ignore_patterns": {
					"scope": "window",
					"type": "array",
					"description": "%configuration.cwtools.ignore_patterns.description%",
					"uniqueItems": true,
					"default": [
						"**/99_README**.txt"
					]
				},
				"cwtools.cache.eu4": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.eu4.description%"
				},
				"cwtools.cache.hoi4": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.hoi4.description%"
				},
				"cwtools.cache.stellaris": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.stellaris.description%"
				},
				"cwtools.cache.ck2": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.ck2.description%"
				},
				"cwtools.cache.imperator": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.imperator.description%"
				},
				"cwtools.cache.vic2": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.vic2.description%"
				},
				"cwtools.cache.ck3": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.ck3.description%"
				},
				"cwtools.cache.vic3": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.vic3.description%"
				},
				"cwtools.cache.eu5": {
					"scope": "application",
					"type": "string",
					"description": "%configuration.cwtools.cache.eu5.description%"
				},
				"cwtools.maxFileSize": {
					"scope": "resource",
					"type": "integer",
					"minimum": 1,
					"default": 2,
					"description": "%configuration.cwtools.maxFileSize.description%"
				},
				"cwtools.ai.enabled": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "Enable AI-assisted code generation and completion"
				},
				"cwtools.ai.provider": {
					"scope": "window",
					"type": "string",
					"enum": ["openai", "claude", "deepseek", "minimax", "glm", "qwen", "ollama", "custom"],
					"enumDescriptions": ["OpenAI (GPT-5.4)", "Claude (Anthropic)", "DeepSeek", "MiniMax", "GLM (智谱)", "Qwen (通义千问)", "Ollama (本地模型)", "Custom OpenAI-compatible"],
					"default": "openai",
					"description": "AI service provider"
				},
				"cwtools.ai.model": {
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "AI model name (leave empty for provider default)"
				},
				"cwtools.ai.endpoint": {
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "Custom API endpoint URL (only for 'custom'/'ollama' provider or endpoint override)"
				},
				"cwtools.ai.agentFileWriteMode": {
					"scope": "window",
					"type": "string",
					"enum": ["confirm", "auto"],
					"enumDescriptions": ["写操作前弹出 diff 确认（默认，安全）", "自动写入，无需确认（高级用户）"],
					"default": "confirm",
					"description": "Agent 文件写入模式：confirm=弹出diff确认后写入，auto=直接写入"
				},
				"cwtools.ai.maxRetries": {
					"scope": "window",
					"type": "integer",
					"default": 3,
					"minimum": 1,
					"maximum": 5,
					"description": "Maximum validation-retry rounds for generated code"
				},
				"cwtools.ai.maxContextTokens": {
					"scope": "window",
					"type": "integer",
					"default": 0,
					"minimum": 0,
					"maximum": 10000000,
					"description": "Override max context window size (tokens). 0 = use provider default. Useful for Ollama or custom providers."
				},
				"cwtools.ai.inlineCompletion.enabled": {
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "Enable AI inline code completion"
				},
				"cwtools.ai.inlineCompletion.debounceMs": {
					"scope": "window",
					"type": "integer",
					"default": 1500,
					"minimum": 500,
					"maximum": 5000,
					"description": "Delay before triggering inline AI completion (ms)"
				},
				"cwtools.ai.inlineCompletion.provider": {
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "Provider for inline completion (leave empty to use main provider)"
				},
				"cwtools.ai.inlineCompletion.model": {
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "Model for inline completion (can differ from chat model, e.g. use a faster model)"
				},
				"cwtools.ai.inlineCompletion.endpoint": {
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "Custom endpoint for inline completion provider (leave empty to use provider default)"
				}
			}
		},
