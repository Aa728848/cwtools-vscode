					"",
					"paradox",
					"pdxscript"
				],
				"extensions": [
					"txt",
					"gui",
					"gfx",
					"asset",
					"cwt"
				],
				"configuration": "./language-configuration.json",
				"filenamePatterns": [
					"**/imperator*/**/*.txt",
					"**/imperator*/**/*.gui",
					"**/imperator*/**/*.gfx",
					"**/imperator*/**/*.sfx",
					"**/imperator*/**/*.asset"
				]
			},
			{
				"id": "vic2",
				"aliases": [
					"",
					"paradox",
					"pdxscript"
				],
				"extensions": [
					"txt",
					"gui",
					"gfx",
					"sfx",
					"asset",
					"cwt",
					"map"
				],
				"configuration": "./language-configuration.json",
				"filenamePatterns": [
					"**/victoria*2/**/*.txt",
